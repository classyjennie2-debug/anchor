# Copy this file to .env and update values before running locally.
DATABASE_URL="file:./dev.db"
SESSION_SECRET="replace-this-with-a-secure-random-string"

# Careers application email delivery
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
CAREERS_RECEIVER_EMAIL="careers@yourcompany.com"
CAREERS_SENDER_EMAIL="careers@yourcompany.com"
